{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/orbit-backend/src/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/orbit-frontend-premium/dist/index.html"
    }
  ],
  "builds": [
    {
      "src": "orbit-frontend-premium/package.json",
      "use": "@vercel/vite"
    },
    {
      "src": "orbit-backend/src/server.js",
      "use": "@vercel/node"
    }
  ]
}